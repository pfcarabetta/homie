# ── Required ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://homie:homie@localhost:5432/homie
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Optional (features degrade gracefully without these) ─────────────────────

# PORT=3001
# API_BASE_URL=https://api.homie.app
# CORS_ORIGIN=https://yourdomain.com  (comma-separated for multiple origins)

# Anthropic (diagnostic chat + voice conversation)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Whisper speech-to-text for the Quote voice channel)
# OPENAI_API_KEY=sk-proj-...

# ElevenLabs (text-to-speech for the Quote voice channel)
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # Optional — defaults to "Adam" (warm, American)

# Twilio (voice/SMS outreach + notifications)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# SendGrid (email notifications)
# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=hello@homie.app

# Google Maps (provider discovery)
# GOOGLE_MAPS_API_KEY=AIza...

# Yelp Fusion (supplementary provider discovery)
# YELP_API_KEY=...

# Webhooks
# WEBHOOK_SECRET=...
# CALLBACK_PHONE=+18005550100
